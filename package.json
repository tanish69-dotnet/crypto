{
  "name": "cryptonova",
  "version": "1.0.0",
  "description": "Premium crypto intelligence dashboard",
  "scripts": {
    "dev": "concurrently -n \"SERVER,CLIENT\" -c \"cyan.bold,magenta.bold\" \"nodemon server/index.js\" \"npm run dev --prefix client\"",
    "server": "node server/index.js",
    "install:all": "npm install && npm install --prefix client",
    "build": "npm run build --prefix client"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}
